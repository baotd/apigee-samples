<AssignMessage async="false" continueOnError="false" enabled="true" name="AM-SetEndUserId">
  <DisplayName>AM-SetEndUserId</DisplayName>
  <!-- 1. Gán enduser_id bằng claim sub (luôn tồn tại cho cả User và Service Account) -->
  <AssignVariable>
    <Name>enduser_id</Name>
    <Ref>jwt.JWT-VerifyGoogleIdToken.decoded.claim.sub</Ref>
    <Value>unknown</Value>
  </AssignVariable>
  <!-- 2. Cố gắng ghi đè bằng claim email (chỉ tồn tại cho User thật). 
       Nếu không tồn tại, Apigee sẽ bỏ qua và giữ nguyên giá trị sub ở trên. -->
  <AssignVariable>
    <Name>enduser_id</Name>
    <Ref>jwt.JWT-VerifyGoogleIdToken.decoded.claim.email</Ref>
  </AssignVariable>
  <IgnoreUnresolvedVariables>true</IgnoreUnresolvedVariables>
</AssignMessage>
