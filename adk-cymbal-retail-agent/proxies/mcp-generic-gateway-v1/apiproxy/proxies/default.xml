<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<ProxyEndpoint name="default">
  <PreFlow name="PreFlow">
    <Request>
      <Step>
        <Name>AM-SaveReq</Name>
      </Step>
      <Step>
        <Name>CORS-Allow</Name>
      </Step>
      <Step>
        <Name>VAK-Check</Name>
      </Step>
      <Step>
        <Name>EV-ExtractServiceName</Name>
      </Step>
      <Step>
        <Name>AM-BuildKVMKeys</Name>
      </Step>
      <Step>
        <Name>KVM-GetMCPConfigs</Name>
      </Step>
      <Step>
        <Name>JS-ParseMCPReq</Name>
        <Condition>request.verb = "POST" and request.header.Content-Type = "application/json"</Condition>
      </Step>
    </Request>
    <Response/>
  </PreFlow>
  <PostFlow name="PostFlow">
    <Request/>
    <Response/>
  </PostFlow>
  <Flows>
    <Flow name="initialize">
      <Response>
        <Step>
          <Name>AM-InitializeRes</Name>
        </Step>
      </Response>
      <Condition>request.verb = "POST" and mcp.method = "initialize"</Condition>
    </Flow>
    <Flow name="initialized">
      <Response>
        <Step>
          <Name>AM-InitializedRes</Name>
        </Step>
      </Response>
      <Condition>request.verb = "POST" and mcp.method = "notifications/initialized"</Condition>
    </Flow>
    <Flow name="ping">
      <Response>
        <Step>
          <Name>AM-PingRes</Name>
        </Step>
      </Response>
      <Condition>request.verb = "POST" and mcp.method = "ping"</Condition>
    </Flow>
    <Flow name="tools/list">
      <Response>
        <Step>
          <Name>JS-ToolsListRes</Name>
        </Step>
      </Response>
      <Condition>request.verb = "POST" and mcp.method = "tools/list"</Condition>
    </Flow>
    <Flow name="tools/call">
      <Condition>request.verb = "POST" and mcp.method = "tools/call"</Condition>
    </Flow>
    <Flow name="method-404">
      <Request>
        <Step>
          <Name>RF-Method404</Name>
        </Step>
      </Request>
      <Condition>true</Condition>
    </Flow>
  </Flows>
  <HTTPProxyConnection>
    <BasePath>/mcp/v1/samples/adk-cymbal-retail</BasePath>
  </HTTPProxyConnection>
  <RouteRule name="tool-call">
    <TargetEndpoint>tool-call</TargetEndpoint>
    <Condition>mcp.method = "tools/call"</Condition>
  </RouteRule>
  <RouteRule name="no-op"/>
</ProxyEndpoint>
